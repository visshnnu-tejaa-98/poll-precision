// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PollStatus {
  DRAFT
  ACTIVE
  EXPIRED
}

model User {
  id          String   @id @default(cuid())
  clerkUserId String
  email       String   @unique
  firstName   String
  lastName    String
  polls       Poll[]
  createdAt   DateTime @default(now())
}

model Poll {
  id                   String     @id @default(cuid())
  title                String
  description          String?
  creatorId            String
  creator              User       @relation(fields: [creatorId], references: [id])
  expiresAt            DateTime?
  status               PollStatus @default(ACTIVE)
  questions            Question[]
  responses            Response[]
  allowAnonymous       Boolean    @default(true)
  authenticatedOnly    Boolean    @default(false)
  resultsVisibility    Boolean    @default(false)
  isPublished          Boolean    @default(false)
  allowResponseEditing Boolean    @default(false)
  responseTimer        Boolean
  timerInMinutes       Int
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
}

model Question {
  id         String           @id @default(cuid())
  pollId     String
  poll       Poll             @relation(fields: [pollId], references: [id])
  title      String
  isRequired Boolean          @default(false)
  options    QuestionOption[]
  order      Int
  answers    Answer[]
}

model QuestionOption {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id])
  text       String
  answers    Answer[]
}

model Response {
  id           String   @id @default(cuid())
  pollId       String
  poll         Poll     @relation(fields: [pollId], references: [id])
  respondentId String?
  isAnonymous  Boolean
  answers      Answer[]
  submittedAt  DateTime @default(now())

  @@unique([pollId, respondentId])
}

model Answer {
  id         String         @id @default(cuid())
  responseId String
  response   Response       @relation(fields: [responseId], references: [id])
  questionId String
  question   Question       @relation(fields: [questionId], references: [id])
  optionId   String
  option     QuestionOption @relation(fields: [optionId], references: [id])
}
